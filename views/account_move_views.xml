<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Affiche le(s) véhicule(s) lié(s) sous le champ client dans la facture -->
    <record id="view_account_move_form_vehicle" model="ir.ui.view">
        <field name="name">account.move.form.vehicle</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_left_group']/div[field[@name='partner_id']]"
                   position="after">
                <field name="repair_vehicle_ids"
                       string="Véhicule(s)"
                       readonly="1"
                       widget="many2many_tags"
                       invisible="not repair_vehicle_ids or move_type not in ('out_invoice', 'out_refund')"
                       options="{'no_create': True, 'no_edit': True, 'no_open': False}"/>
                <field name="repair_vehicle_info"
                       string="Kilométrage"
                       readonly="1"
                       invisible="not repair_vehicle_info or move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>
</odoo>
