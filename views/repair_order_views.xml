<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Héritage de la vue formulaire native repair.order
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_repair_order_form_garage" model="ir.ui.view">
        <field name="name">repair.order.form.garage</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">

            <!-- 1. Smart button factures dans button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_invoices" type="object"
                        class="oe_stat_button" icon="fa-pencil-square-o"
                        invisible="invoice_count == 0">
                    <field name="invoice_count" widget="statinfo" string="Factures"/>
                </button>
                <button name="action_view_comebacks" type="object"
                        class="oe_stat_button" icon="fa-undo"
                        invisible="comeback_count == 0">
                    <field name="comeback_count" widget="statinfo" string="Retours atelier"/>
                </button>
            </xpath>

            <!-- 2. Réorganisation complète du groupe principal -->
            <xpath expr="//group[field[@name='repair_properties']]" position="replace">
                <group>
                    <!-- ── Colonne gauche ──────────────────────────────── -->
                    <group>
                        <field name="allowed_lot_ids" invisible="1"/>
                        <field name="repair_request" invisible="not sale_order_line_id"/>
                        <field name="product_uom_category_id" invisible="1"/>
                        <field name="product_id" string="Produit à réparer" readonly="1"/>
                        <field name="vehicle_id"
                               context="{'default_partner_id': partner_id}"
                               options="{'no_quick_create': True}"/>
                        <field name="partner_id" widget="res_partner_many2one"
                               context="{'res_partner_search_mode': 'customer', 'show_vat': True}"
                               readonly="sale_order_id"/>
                        <field name="lot_id" context="{'default_product_id': product_id}"
                               groups="stock.group_production_lot"
                               options="{'no_create': True, 'no_create_edit': True}"
                               invisible="tracking not in ['serial', 'lot']"
                               readonly="state == 'done'"
                               required="tracking in ['serial', 'lot']"/>
                        <label for="product_qty" invisible="not product_id"/>
                        <div class="o_row" invisible="not product_id">
                            <field name="product_qty" readonly="tracking == 'serial' or state in ('done', 'cancel')"/>
                            <field name="product_uom" groups="uom.group_uom" readonly="state != 'draft'"/>
                        </div>
                        <field name="mileage_in" string="Km entrée" invisible="not vehicle_id"/>
                        <field name="fuel_level" invisible="not vehicle_id"/>
                        <field name="repair_origin_id"
                               domain="[('state', '=', 'done')]"
                               options="{'no_create': True}"
                               placeholder="Laisser vide si nouvelle intervention"/>
                        <field name="under_warranty" readonly="state in ['cancel', 'done']"/>
                    </group>
                    <!-- ── Colonne droite ──────────────────────────────── -->
                    <group>
                        <field name="date_checkin"/>
                        <field name="schedule_date" readonly="state in ['done', 'cancel']"/>
                        <field name="estimated_completion"/>
                        <field name="user_id" domain="[('share', '=', False)]"/>
                        <field name="tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color', 'no_create_edit': True}"
                               placeholder="Vidange | Freinage | Diagnostic…"/>
                        <field name="picking_id" invisible="1"/>
                        <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        <field name="parts_availability_state" invisible="True"/>
                        <field name="parts_availability"
                               invisible="state not in ['confirmed', 'under_repair']"
                               decoration-success="parts_availability_state == 'available'"
                               decoration-warning="parts_availability_state == 'expected'"
                               decoration-danger="parts_availability_state == 'late'"/>
                    </group>
                    <field name="repair_properties" nolabel="1" columns="2" hideAddButton="1"/>
                </group>
            </xpath>

            <!-- 3. Page "Réception / Restitution" dans le notebook (avant "Repair Notes") -->
            <xpath expr="//page[@name='repair_notes']" position="before">
                <page string="Réception / Restitution" name="garage_reception">
                    <group>
                        <group string="Plainte client">
                            <field name="customer_complaint" nolabel="1"
                                   placeholder="Décrire le problème signalé par le client…"/>
                        </group>
                        <group string="Diagnostic technicien">
                            <field name="diagnosis_notes" nolabel="1"
                                   placeholder="Observations et conclusions du technicien…"/>
                        </group>
                    </group>
                    <group>
                        <group string="Restitution">
                            <field name="mileage_out" string="Km sortie" invisible="not vehicle_id"/>
                            <field name="date_checkout" invisible="not vehicle_id"/>
                        </group>
                        <group string="Totaux">
                            <field name="labor_total" string="Main-d'œuvre"/>
                            <field name="parts_total" string="Pièces"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <!-- 4. Champs techniques invisibles requis pour les computed -->
            <xpath expr="//form/field[@name='has_uncomplete_moves']" position="after">
                <field name="invoice_count" invisible="1"/>
                <field name="invoice_state" invisible="1"/>
                <field name="comeback_count" invisible="1"/>
            </xpath>

        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Vue liste enrichie avec colonne véhicule
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_repair_order_list_garage" model="ir.ui.view">
        <field name="name">repair.order.list.garage</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_tree"/>
        <field name="arch" type="xml">
            <!-- Insérer la colonne véhicule juste après le numéro d'ordre -->
            <xpath expr="//list/field[@name='name']" position="after">
                <field name="vehicle_id" string="Véhicule" optional="show"/>
            </xpath>
            <xpath expr="//list/field[@name='partner_id']" position="after">
                <field name="mileage_in" string="Km entrée" optional="hide"/>
                <field name="date_checkin" string="Entrée" optional="hide"/>
            </xpath>
            <!-- Remplacer schedule_date : affichage relatif, rouge uniquement si ordre actif -->
            <xpath expr="//list/field[@name='schedule_date']" position="replace">
                <field name="schedule_date" optional="show"
                       widget="repair_remaining_days"/>
            </xpath>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Action liste ordres de réparation (utilisée par notre menu)
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="action_repair_auto_order_list" model="ir.actions.act_window">
        <field name="name">Interventions</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">list,form,kanban,graph,pivot</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un ordre de réparation
            </p>
            <p>
                Gérez toutes les interventions de votre garage,
                de la prise en charge à la restitution du véhicule.
            </p>
        </field>
    </record>
</odoo>
