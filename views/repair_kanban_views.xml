<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Vue Kanban — tableau de bord des interventions
         Groupé par state, carte avec immatriculation + client + tags
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_repair_kanban_garage" model="ir.ui.view">
        <field name="name">repair.order.kanban.garage</field>
        <field name="model">repair.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1"
                    class="o_kanban_small_column"
                    records_draggable="0"
                    quick_create="false"
                    group_create="false"
                    group_delete="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="vehicle_id"/>
                <field name="schedule_date"/>
                <field name="schedule_date_only"/>
                <field name="state"/>
                <field name="tag_ids"/>
                <field name="user_id"/>
                <field name="priority"/>
                <field name="vehicle_brand_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">

                            <!-- En-tête : N° ordre + priorité (même ligne) -->
                            <div class="o_kanban_record_top mb-1 d-flex align-items-center justify-content-between">
                                <strong class="o_kanban_record_title text-truncate">
                                    <field name="name"/>
                                </strong>
                                <field name="priority" widget="priority"/>
                            </div>

                            <!-- Véhicule : logo marque + nom -->
                            <div t-if="record.vehicle_id.raw_value"
                                 class="d-flex align-items-center gap-1 o_kanban_record_subtitle mb-1">
                                <img t-if="record.vehicle_brand_id.raw_value"
                                     t-att-src="'/web/image/garage.vehicle.brand/' + record.vehicle_brand_id.raw_value + '/image_128'"
                                     style="height:24px;width:auto;object-fit:contain;flex-shrink:0;"
                                     class="me-1"/>
                                <i t-else="" class="fa fa-car me-1" title="Véhicule"/>
                                <field name="vehicle_id"/>
                            </div>

                            <!-- Client -->
                            <div class="d-flex align-items-center gap-1 o_kanban_record_subtitle mb-1">
                                <i class="fa fa-user-o me-1" title="Client"/>
                                <field name="partner_id"/>
                            </div>

                            <!-- Date planifiée (rouge si dépassée et pas terminé/annulé) -->
                            <div t-if="record.schedule_date_only.raw_value"
                                 class="d-flex align-items-center gap-1 o_kanban_record_subtitle"
                                 t-att-class="{'text-danger fw-semibold': new Date(record.schedule_date_only.raw_value) &lt; new Date() &amp;&amp; record.state.raw_value !== 'done' &amp;&amp; record.state.raw_value !== 'cancel', 'text-muted': !(new Date(record.schedule_date_only.raw_value) &lt; new Date() &amp;&amp; record.state.raw_value !== 'done' &amp;&amp; record.state.raw_value !== 'cancel')}">
                                <i class="fa fa-calendar me-1" title="Date planifiée"/>
                                <field name="schedule_date_only"/>
                            </div>

                            <!-- Pied de carte : tags + responsable (texte) -->
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left flex-wrap gap-1">
                                    <field name="tag_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                </div>
                                <div t-if="record.user_id.raw_value"
                                     class="oe_kanban_bottom_right d-flex align-items-center gap-1 text-muted small">
                                    <i class="fa fa-wrench" title="Responsable"/>
                                    <field name="user_id"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action dédiée au tableau de bord Kanban -->
    <record id="action_repair_auto_kanban" model="ir.actions.act_window">
        <field name="name">Tableau de bord</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_repair_kanban_garage"/>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune intervention en cours
            </p>
        </field>
    </record>

    <!-- Filtre "en cours" pour le kanban dashboard -->
    <record id="view_repair_order_search_garage" model="ir.ui.view">
        <field name="name">repair.order.search.garage</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="En cours" name="in_progress"
                        domain="[('state', 'in', ['confirmed', 'under_repair'])]"/>
                <filter string="Avec véhicule" name="with_vehicle"
                        domain="[('vehicle_id', '!=', False)]"/>
                <field name="vehicle_id" string="Véhicule"/>
            </xpath>
        </field>
    </record>
</odoo>
