<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Vue Kanban — tableau de bord des interventions
         Groupé par state, carte avec immatriculation + client + tags
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_repair_kanban_garage" model="ir.ui.view">
        <field name="name">repair.order.kanban.garage</field>
        <field name="model">repair.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1"
                    class="o_kanban_small_column"
                    records_draggable="0">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="vehicle_id"/>
                <field name="schedule_date"/>
                <field name="state"/>
                <field name="tag_ids"/>
                <field name="user_id"/>
                <field name="priority"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <!-- En-tête : N° ordre + priorité -->
                            <div class="o_kanban_record_top mb4">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <!-- Véhicule -->
                            <div t-if="record.vehicle_id.raw_value" class="o_kanban_record_subtitle">
                                <i class="fa fa-car me-1"/>
                                <field name="vehicle_id"/>
                            </div>
                            <!-- Client -->
                            <div class="o_kanban_record_subtitle">
                                <field name="partner_id" widget="res_partner_many2one"/>
                            </div>
                            <!-- Date planifiée -->
                            <div t-if="record.schedule_date.raw_value" class="o_kanban_record_subtitle text-muted">
                                <i class="fa fa-calendar me-1"/>
                                <field name="schedule_date" widget="date"/>
                            </div>
                            <!-- Bas de carte : avatar utilisateur + tags -->
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="tag_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action dédiée au tableau de bord Kanban -->
    <record id="action_repair_auto_kanban" model="ir.actions.act_window">
        <field name="name">Tableau de bord</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_repair_kanban_garage"/>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune intervention en cours
            </p>
        </field>
    </record>

    <!-- Filtre "en cours" pour le kanban dashboard -->
    <record id="view_repair_order_search_garage" model="ir.ui.view">
        <field name="name">repair.order.search.garage</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="En cours" name="in_progress"
                        domain="[('state', 'in', ['confirmed', 'under_repair'])]"/>
                <filter string="Avec véhicule" name="with_vehicle"
                        domain="[('vehicle_id', '!=', False)]"/>
                <field name="vehicle_id" string="Véhicule"/>
            </xpath>
        </field>
    </record>
</odoo>
