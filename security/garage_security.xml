<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Catégorie -->
    <record id="module_category_garage_auto" model="ir.module.category">
        <field name="name">Garage Auto</field>
        <field name="description">Gestion professionnelle des garages automobiles</field>
        <field name="sequence">45</field>
    </record>

    <!-- Groupes -->
    <record id="group_garage_reception" model="res.groups">
        <field name="name">Réception</field>
        <field name="category_id" ref="module_category_garage_auto"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Accès à la réception : création et modification des ordres de réparation et fiches véhicule.</field>
    </record>

    <record id="group_garage_technician" model="res.groups">
        <field name="name">Technicien</field>
        <field name="category_id" ref="module_category_garage_auto"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Accès technicien : lecture des ordres de réparation et saisie des heures.</field>
    </record>

    <record id="group_garage_manager" model="res.groups">
        <field name="name">Responsable</field>
        <field name="category_id" ref="module_category_garage_auto"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('group_garage_reception')),
            (4, ref('group_garage_technician')),
            (4, ref('stock.group_stock_manager')),
        ]"/>
        <field name="comment">Accès complet : configuration, suppression, analyse.</field>
    </record>

    <!-- Règle multi-société sur garage.vehicle -->
    <record id="rule_garage_vehicle_company" model="ir.rule">
        <field name="name">Véhicule — règle multi-société</field>
        <field name="model_id" search="[('model','=','garage.vehicle')]" model="ir.model"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
